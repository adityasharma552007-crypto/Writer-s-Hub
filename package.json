{
    "name": "writers-hub",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:client": "npm run dev --workspace=client",
        "dev:server": "npm run dev --workspace=server"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.99.0"
    }
}
